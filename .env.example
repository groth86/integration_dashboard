# Railway Postgres connection string (use the pooled URL for serverless deploys)
DATABASE_URL="postgresql://user:password@host:port/database"

# Secret used to sign session JWTs. Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"

# Password for the initial admin user created by the seed script
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="change-me-on-first-login"
